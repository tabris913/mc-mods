// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/java
{
  "name": "Java",
  // Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
  "build": {
    "dockerfile": "Dockerfile"
  },

  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "none",
      "installMaven": "true",
      "installGradle": "false"
    },
    "ghcr.io/devcontainers/features/node:1": {}
  },
  "mounts": [
    {
      "source": "kiro-config",
      "target": "/home/vscode/.kiro",
      "type": "volume"
    },
    {
      "source": "kiro-cli-data",
      "target": "/home/vscode/.local/share/kiro-cli",
      "type": "volume"
    }
  ],
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",

  // Use 'forwardPorts' to make a list of ports inside the container available locally.
  // "forwardPorts": [],

  // Use 'postCreateCommand' to run commands after the container is created.
  "initializeCommand": "bash .devcontainer/initialize.sh",
  "postCreateCommand": "bash .devcontainer/postCreate.sh",

  // Configure tool-specific properties.
  "customizations": {
    "vscode": {
      "extensions": [
        "AkankshaSingh872.case-change", // Case Change
        "mhutchie.git-graph", // Git Graph
        "donjayamanne.githistory", // Git History
        "eamodio.gitlens", // GitLens
        "ryu1kn.partial-diff", // Partial Diff
        "esbenp.prettier-vscode", // Prettier
        "chrmarti.regex", // Regax Previewer
        "Gruntfuggly.todo-tree", // Todo Tree
        // file utilities
        "yzhang.markdown-all-in-one", // Markdown All in One
        "yzane.markdown-pdf", // Markdown PDF
        "shd101wyy.markdown-preview-enhanced", // Markdown Preview Enhanced
        "alanwalk.markdown-toc", // Markdown TOC
        "richie5um2.vscode-sort-json", // Sort JSON objects
        "3w36zj6.textlint", // textlint
        "dotjoshjohnson.xml", // XML Tools
        // java
        "redhat.vscode-community-server-connector", // Community Server Connectors
        "vscjava.vscode-java-pack", // Extension Pack for Java
        "madhavd1.javadoc-tools", // Javadoc Tools
        "redhat.java", // Language Support for Java
        "gabrielbb.vscode-lombok", // Lombok Annotations Support
        "vscjava.vscode-maven", // Maven for Java
        "josevseb.google-java-format-for-vs-code"
      ]
    }
  }

  // Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
  // "remoteUser": "root"
}
